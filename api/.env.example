# Backend (.env) example

# Logging and observability
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# CORS: comma-separated list of allowed origins (set for staging/prod). Dev localhost defaults are always allowed.
CORS_ORIGINS=https://family.example.com,https://admin.example.com

# Firebase Admin SDK
# In production, prefer providing the JSON string via env var
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or for local dev, place serviceAccountKey.json at project root and leave above empty
FIREBASE_STORAGE_BUCKET=

# Optional AI features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
